{
  "$schema": "product-os-metrics-contract-v1",
  "project_id": "chief-of-staff-experience",
  "north_star_metric": {
    "name": "Approval-complete action loop rate",
    "definition": "% of extracted action items completed or explicitly deferred within 7 days",
    "unit": "percentage",
    "window": "7d",
    "segmentation": [
      "workspace",
      "persona",
      "surface"
    ]
  },
  "instrumentation": {
    "required_events": [
      {
        "event_name": "cos_action_item_completed",
        "description": "Action item completion event for accountability loop",
        "required_properties": [
          "user_id",
          "item_id",
          "source",
          "days_to_complete",
          "workspace_id",
          "initiative_id"
        ],
        "mapped_posthog_insight_ids": [],
        "mapped_dashboard_ids": []
      },
      {
        "event_name": "cos_action_item_dismissed",
        "description": "Action dismissed without completion; denominator for loop quality",
        "required_properties": [
          "user_id",
          "item_id",
          "reason",
          "workspace_id",
          "initiative_id"
        ],
        "mapped_posthog_insight_ids": [],
        "mapped_dashboard_ids": []
      },
      {
        "event_name": "cos_feed_item_reviewed",
        "description": "Engagement leading indicator for action-taking behavior",
        "required_properties": [
          "user_id",
          "item_id",
          "item_type",
          "priority",
          "workspace_id",
          "initiative_id"
        ],
        "mapped_posthog_insight_ids": [],
        "mapped_dashboard_ids": []
      },
      {
        "event_name": "cos_draft_approved",
        "description": "Draft approval behavior used for cognitive load proxy",
        "required_properties": [
          "user_id",
          "item_id",
          "channel",
          "time_to_approve_seconds",
          "workspace_id",
          "initiative_id"
        ],
        "mapped_posthog_insight_ids": [],
        "mapped_dashboard_ids": []
      }
    ],
    "posthog": {
      "dashboard_ids": [],
      "insight_ids": []
    }
  },
