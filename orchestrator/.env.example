# =============================================================================
# Environment Variables for PM Orchestrator
# =============================================================================
# Copy this file to .env.local and fill in the values
# cp .env.example .env.local

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# The app supports two database modes:
#
# 1. LOCAL DEVELOPMENT (Docker PostgreSQL) - RECOMMENDED for development
#    Use a standard PostgreSQL connection string:
#    DATABASE_URL=postgresql://elmer:elmer_local_dev@localhost:5433/orchestrator
#
# 2. NEON SERVERLESS (Production/Cloud)
#    If your URL contains "neon.tech", the app automatically uses the
#    serverless HTTP driver optimized for Vercel Edge:
#    DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/database?sslmode=require
#
# The app auto-detects which driver to use based on the URL pattern.

# For LOCAL development with Docker:
DATABASE_URL=postgresql://elmer:elmer_local_dev@localhost:5433/orchestrator

# For NEON serverless (comment out local and uncomment this):
# DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# =============================================================================
# AUTHENTICATION (Clerk + Convex)
# =============================================================================
# Clerk powers the app shell authentication. If you use a custom Clerk domain,
# CLERK_JWT_ISSUER_DOMAIN must match the Clerk frontend API host exactly.
# Example custom-domain setup:
# - clerk.elmer.studio      CNAME frontend-api.clerk.services
# - accounts.elmer.studio   CNAME accounts.clerk.services
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key
CLERK_JWT_ISSUER_DOMAIN=https://your-frontend-api.clerk.accounts.dev
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/workspace
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/workspace

# Convex auth/runtime
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_SITE_URL=https://your-deployment.convex.site
MCP_SECRET=elmer-mcp-internal

# Legacy NextAuth bridge for GitHub connection flows that have not migrated yet
# AUTH_URL and NEXTAUTH_URL should both point at the app origin, not the Clerk
# frontend API host, and should match each other when both are set.
AUTH_SECRET=your-auth-secret-here
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# =============================================================================
# GOOGLE OAUTH (required for "Sign in with Google")
# =============================================================================
# To set up Google OAuth:
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create or select a project
# 3. Click "Create Credentials" → "OAuth client ID"
# 4. Choose "Web application"
# 5. Add Authorized redirect URIs:
#    - http://localhost:3000/api/auth/callback/google (development)
#    - https://your-domain.com/api/auth/callback/google (production)
# 6. Copy Client ID and Client Secret below
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# =============================================================================
# GITHUB OAUTH (optional - for repository integration)
# =============================================================================
# To set up GitHub OAuth:
# 1. Go to https://github.com/settings/developers
# 2. Click "New OAuth App"
# 3. Set Authorization callback URL:
#    - http://localhost:3000/api/auth/callback/github (development)
#    - https://your-domain.com/api/auth/callback/github (production)
# 4. Copy Client ID and Client Secret below
#
# Note: GitHub OAuth enables:
# - Repository selection dropdown (instead of manual path entry)
# - Auto-configure context paths based on repo structure
# - Access to private repositories
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# =============================================================================
# AI CONFIGURATION
# =============================================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key (for text embeddings using text-embedding-3-small)
# Get your API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# =============================================================================
# OPTIONAL: INTEGRATIONS
# =============================================================================

# Linear API (for ticket management)
# LINEAR_API_KEY=your_linear_api_key

# PostHog (for analytics)
# NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Notion (for knowledge sync)
# NOTION_API_KEY=your_notion_api_key

# =============================================================================
# CHROMATIC (Storybook Visual Testing & Embedding)
# =============================================================================
# Get your project token from https://www.chromatic.com/start
# This enables:
# - Auto-publishing prototypes to Chromatic
# - Embedding Storybook stories directly in the app
CHROMATIC_PROJECT_TOKEN=your_chromatic_project_token

# =============================================================================
# QUICK START: Local Development
# =============================================================================
# 1. Start PostgreSQL:
#    docker compose up -d
#
# 2. Run migrations:
#    npm run db:migrate
#
# 3. Start the dev server:
#    npm run dev
#
# 4. Run an auth smoke check:
#    npm run check:auth
#
# 5. Open http://localhost:3000
#
# 6. E2E (optional):
#    E2E_TEST_EMAIL=...
#    E2E_TEST_PASSWORD=...
#    npm run test:e2e -- --project=setup
